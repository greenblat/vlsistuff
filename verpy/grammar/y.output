  264 pragma_stuffs: pragma_stuffs ',' pragma_item
  265              | pragma_item

  266 pragma_item: token '=' Expr
  267            | string

  268 Pragma: pragma1 pragma_stuffs pragma2

  269 For_statement: for '(' Soft_assigns ';' Expr ';' Soft_assigns ')' Statement
  270              | for '(' int Soft_assign ';' Expr ';' Soft_assigns ')' Statement

  271 Repeat_statement: repeat '(' Expr ')' Statement

  272 While_statement: while '(' Expr ')' Statement

  273 Soft_assigns: Soft_assigns ',' Soft_assign
  274             | Soft_assign

  275 Soft_assign: LSH '=' Expr
  276            | LSH plus_plus

  277 Cases: Cases Case
  278      | Case

  279 GenCases: GenCases GenCase
  280         | GenCase

  281 Case: Exprs ':' Statement
  282     | Exprs ':' ';'

  283 GenCase: Exprs ':' GenStatement
  284        | Exprs ':' ';'

  285 Default: default ':' Statement
  286        | default ':' ';'

  287 GenDefault: default ':' GenStatement
  288           | default ':' ';'

  289 Exprs: Exprs ',' Expr
  290      | Expr

  291 Statements: Statements Statement
  292           | Statement

  293 LSH: token
  294    | token Width
  295    | token BusBit Width
  296    | token BusBit BusBit
  297    | token BusBit
  298    | CurlyList

  299 Tokens_list: token ',' Tokens_list
