Grammar

    0 $accept: Main $end

    1 Main: Mains

    2 Mains: Mains MainItem
    3      | MainItem

    4 MainItem: Module
    5         | Define

    6 Module: module token Hparams Header Module_stuffs endmodule
    7       | module token Hparams Header endmodule
    8       | module token Header Module_stuffs endmodule
    9       | module token Header endmodule

   10 Hparams: '#' '(' head_params ')'
   11        | '#' '(' ')'

   12 Header: ';'
   13       | '(' Header_list ')' ';'
   14       | '(' ')' ';'

   15 Header_list: Header_list ',' Header_item
   16            | Header_item

   17 Header_item: ExtDir token
   18            | ExtDir Width token
   19            | ExtDir integer token
   20            | ExtDir Width token Width
   21            | ExtDir Width Width token
   22            | ExtDir Width Width Width token
   23            | token
   24            | ExtDir token '=' Literal
   25            | ExtDir Width token '=' Literal

   26 Module_stuffs: Mstuff Module_stuffs
   27              | ε

   28 Mstuff: Definition
   29       | Assign
   30       | Instance
   31       | Always
   32       | Generate
   33       | Parameter
   34       | Localparam
   35       | Defparam
   36       | Initial
   37       | Function
   38       | Task
   39       | Define
   40       | Pragma
   41       | newver

   42 Define: define
   43       | define string
   44       | define token
   45       | define token Expr
   46       | define number token '/' number token

   47 Initial: initial Statement

   48 OneDef: token
   49       | token '=' Expr

   50 ManyDefs: ManyDefs ',' OneDef
   51         | OneDef

   52 Definition: ExtDir Tokens_list ';'
   53           | ExtDir Width Tokens_list ';'
   54           | ExtDir Width Tokens_list Width ';'
   55           | event Tokens_list ';'
   56           | IntDir ManyDefs ';'
   57           | IntDir Width ManyDefs ';'
   58           | IntDir Width Width ManyDefs ';'
   59           | IntDir Width Width Width OneDef ';'
   60           | IntDir Width token Width ';'
   61           | IntDir Width token Width Width ';'
   62           | IntDir Width Width token ';'
   63           | IntDir Width Width Width token ';'
   64           | IntDir token Width ';'
   65           | IntDir InstParams Tokens_list ';'
   66           | IntDir InstParams token '=' Expr ';'
   67           | typedef enum logic Width '{' Tokens_list '}' token ';'
   68           | typedef enum logic '{' Tokens_list '}' token ';'
   69           | typedef enum '{' Tokens_list '}' token ';'
   70           | typedef struct packed '{' RegDefines '}' token ';'
   71           | typedef struct '{' RegDefines '}' token ';'

   72 RegDefines: RegDefine RegDefines
   73           | RegDefine

   74 RegDefine: reg token ';'
   75          | logic token ';'
   76          | bit token ';'
   77          | reg Width token ';'
   78          | logic Width token ';'
   79          | bit Width token ';'

   80 Assign: assign Soft_assigns ';'
   81       | assign AssignParams LSH '=' Expr ';'
   82       | assign StrengthDef AssignParams LSH '=' Expr ';'
   83       | assign StrengthDef LSH '=' Expr ';'

   84 StrengthDef: '(' Strength ',' Strength ')'

   85 Strength: strong1
   86         | strong0
   87         | pull1
   88         | pull0
   89         | weak1
   90         | weak0
   91         | highz1
   92         | highz0

   93 WidthInt: Width
   94         | integer

   95 Function: function token ';' Mem_defs Statements endfunction
   96         | function token ';' Statements endfunction
   97         | function Width Width token ';' Mem_defs Statement endfunction
   98         | function WidthInt token ';' Mem_defs Statement endfunction
   99         | function automatic Width token ';' Mem_defs Statement endfunction
  100         | function automatic token ';' Mem_defs Statement endfunction
  101         | function WidthInt token ';' Statement endfunction
  102         | function token '(' Header_list ')' ';' Statement endfunction
  103         | function token '(' Header_list ')' ';' Mem_defs Statement endfunction
  104         | function automatic token '(' Header_list ')' ';' Statements endfunction
  105         | function automatic token '(' Header_list ')' ';' Mem_defs Statements endfunction
  106         | function automatic token token '(' Header_list ')' ';' Statements endfunction
  107         | function automatic token token '(' Header_list ')' ';' Mem_defs Statements endfunction
  108         | function automatic Width token '(' Header_list ')' ';' Statements endfunction
  109         | function automatic Width token '(' Header_list ')' ';' Mem_defs Statements endfunction
  110         | function WidthInt token '(' Header_list ')' ';' Statements endfunction
  111         | function WidthInt token '(' Header_list ')' ';' Mem_defs Statements endfunction

  112 Task: task token ';' Mem_defs Statement endtask
  113     | task token ';' Statement endtask
  114     | task token '(' Header_list ')' ';' Statement endtask
  115     | task token '(' Header_list ')' ';' Mem_defs Statement endtask

  116 Mem_defs: Mem_defs Mem_def
  117         | Mem_def

  118 Mem_def: reg Tokens_list ';'
  119        | real Tokens_list ';'
  120        | wreal Tokens_list ';'
  121        | reg Width Tokens_list ';'
  122        | reg signed Width Tokens_list ';'
  123        | logic Width Tokens_list ';'
  124        | bit Width Tokens_list ';'
  125        | logic Tokens_list ';'
  126        | bit Tokens_list ';'
  127        | reg Width token Width ';'
  128        | reg Width Width token ';'
  129        | output reg Width Width token ';'
  130        | input Tokens_list ';'
  131        | input Tokens_list Width ';'
  132        | input Width Width Tokens_list ';'
  133        | input Width Tokens_list ';'
  134        | input signed Width Tokens_list ';'
  135        | input integer Tokens_list ';'
  136        | integer Tokens_list ';'
  137        | integer Tokens_list Width ';'
  138        | token token ';'

  139 Parameter: parameter Pairs ';'
  140          | parameter signed Pairs ';'
  141          | parameter Width Pairs ';'
  142          | parameter Width Width Pairs ';'
  143          | parameter signed Width Pairs ';'

  144 Localparam: localparam Pairs ';'
  145           | localparam Width Pairs ';'
  146           | localparam Width Width Pairs ';'

  147 Defparam: defparam Pairs ';'

  148 Pairs: Pairs ',' Pair
  149      | Pair

  150 Pair: token '=' Expr

  151 head_params: head_params ',' head_param
  152            | head_param

  153 head_param: localparam token '=' Expr
  154           | parameter token '=' Expr
  155           | parameter Width token '=' Expr
  156           | token '=' Expr

  157 Instance: token token '(' ')' ';'
  158         | token InstParams token '(' ')' ';'
  159         | token token ';'
  160         | or '(' Exprs ')' ';'
  161         | or token '(' Exprs ')' ';'
  162         | token token '(' Conns_list ')' ';'
  163         | or token '(' Conns_list ')' ';'
  164         | token token '(' Exprs ')' ';'
  165         | token '(' Exprs ')' ';'
  166         | token InstParams token '(' Conns_list ')' ';'
  167         | token InstParams token Width '(' Conns_list ')' ';'
  168         | token token Width '(' Conns_list ')' ';'
  169         | token token Width '(' Exprs ')' ';'

  170 Conns_list: Conns_list ',' Connection
  171           | Connection

  172 Connection: '.' '*'
  173           | '.' token '(' Expr ')'
  174           | '.' token '(' ')'
  175           | '.' token '[' number ']' '(' Expr ')'

  176 AssignParams: '#' '(' Exprs ')'
  177             | '#' number
  178             | '#' token
  179             | '#' floating

  180 Prms_list: Prms_list ',' PrmAssign
  181          | PrmAssign

  182 PrmAssign: '.' token '(' Expr ')'
  183          | '.' token

  184 InstParams: '#' '(' Exprs ')'
  185           | '#' number
  186           | '#' floating
  187           | '#' token
  188           | '#' '(' Prms_list ')'
  189           | '#' '(' ')'

  190 Always: always_ff When Statement
  191       | always_comb Statement
  192       | always Statement
  193       | always When Statement

  194 Generate: generate GenStatements endgenerate

  195 GenStatements: GenStatements GenStatement
  196              | GenStatement

  197 GenStatement: begin GenStatements end
  198             | begin ':' token GenStatements end
  199             | genvar Tokens_list ';'
  200             | Definition
  201             | Assign
  202             | Parameter
  203             | Localparam
  204             | Defparam
  205             | Instance
  206             | GenFor_statement
  207             | Always
  208             | Initial
  209             | Pragma
  210             | if '(' Expr ')' GenStatement
  211             | if '(' Expr ')' GenStatement else GenStatement
  212             | case '(' Expr ')' GenCases endcase
  213             | case '(' Expr ')' GenCases GenDefault endcase
  214             | case '(' Expr ')' GenDefault endcase

  215 GenFor_statement: for '(' Soft_assigns ';' Expr ';' Soft_assigns ')' GenStatement

  216 When: '@' '*'
  217     | '@' star
  218     | '@' token
  219     | '@' '(' When_items ')'

  220 Or_coma: or
  221        | ','

  222 When_items: When_items Or_coma When_item
  223           | When_item

  224 When_item: posedge Expr
  225          | negedge Expr
  226          | Expr

  227 Statement: begin Statements end
  228          | begin end
  229          | forever Statement
  230          | begin ':' token Statements end
  231          | fork Statements join
  232          | LSH '=' Expr ';'
  233          | LSH '=' AssignParams Expr ';'
  234          | LSH sm_eq Expr ';'
  235          | LSH sm_eq AssignParams Expr ';'
  236          | if '(' Expr ')' Statement
  237          | if '(' Expr ')' Statement else Statement
  238          | wait Expr ';'
  239          | integer Tokens_list ';'
  240          | int Tokens_list ';'
  241          | reg Tokens_list ';'
  242          | reg Width Tokens_list ';'
  243          | reg signed Width Tokens_list ';'
  244          | release Expr ';'
  245          | force Expr '=' Expr ';'
  246          | When ';'
  247          | emit token ';'
  248          | disable token ';'
  249          | token '(' ')' ';'
  250          | token '(' Exprs ')' ';'
  251          | case '(' Expr ')' Cases endcase
  252          | case '(' Expr ')' Cases Default endcase
  253          | case '(' Expr ')' Default endcase
  254          | casez '(' Expr ')' Cases endcase
  255          | casez '(' Expr ')' Cases Default endcase
  256          | casex '(' Expr ')' Cases endcase
  257          | casex '(' Expr ')' Cases Default endcase
  258          | '#' Expr ';'
  259          | '#' Expr Statement
  260          | token ';'
  261          | For_statement
  262          | Repeat_statement
  263          | While_statement
  264          | Pragma
  265          | assign LSH '=' Expr ';'
  266          | return token ';'
  267          | assert '(' Expr ')' ';'
  268          | assert '(' Expr ')' else Statement

  269 pragma_stuffs: pragma_stuffs ',' pragma_item
  270              | pragma_item

  271 pragma_item: token '=' Expr
  272            | string

  273 Pragma: pragma1 pragma_stuffs pragma2

  274 For_statement: for '(' Soft_assigns ';' Expr ';' Soft_assigns ')' Statement
  275              | for '(' int Soft_assign ';' Expr ';' Soft_assigns ')' Statement

  276 Repeat_statement: repeat '(' Expr ')' Statement

  277 While_statement: while '(' Expr ')' Statement

  278 Soft_assigns: Soft_assigns ',' Soft_assign
  279             | Soft_assign

  280 Soft_assign: LSH '=' Expr
  281            | LSH plus_plus

  282 Cases: Cases Case
  283      | Case

  284 GenCases: GenCases GenCase
  285         | GenCase

  286 Case: Exprs ':' Statement
  287     | Exprs ':' ';'

  288 GenCase: Exprs ':' GenStatement
  289        | Exprs ':' ';'

  290 Default: default ':' Statement
  291        | default ':' ';'

  292 GenDefault: default ':' GenStatement
  293           | default ':' ';'

  294 Exprs: Exprs ',' Expr
  295      | Expr

  296 Statements: Statements Statement
  297           | Statement

  298 LSH: token
  299    | token Width
  300    | token BusBit Width
  301    | token BusBit BusBit
  302    | token BusBit
  303    | CurlyList

  304 Tokens_list: token ',' Tokens_list
  305            | token

  306 Width: '[' Expr ':' Expr ']'
  307      | '[' Expr plus_range Expr ']'
  308      | '[' Expr minus_range Expr ']'

  309 BusBit: '[' Expr ']'

  310 ExtDir: input
  311       | output
  312       | inout
  313       | output reg
  314       | input wire
  315       | output wire
  316       | inout wire
  317       | input signed
