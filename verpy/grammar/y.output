Grammar

    0 $accept: Main $end

    1 Main: Mains

    2 Mains: Mains MainItem
    3      | MainItem

    4 MainItem: Module
    5         | Define

    6 Module: module token Hparams Header Module_stuffs endmodule
    7       | module token Hparams Header endmodule
    8       | module token Header Module_stuffs endmodule
    9       | module token Header endmodule

   10 Hparams: '#' '(' head_params ')'
   11        | '#' '(' ')'

   12 Header: ';'
   13       | '(' Header_list ')' ';'
   14       | '(' ')' ';'

   15 Header_list: Header_list ',' Header_item
   16            | Header_item

   17 Header_item: ExtDir token
   18            | ExtDir Width token
   19            | ExtDir integer token
   20            | ExtDir Width token Width
   21            | ExtDir Width Width token
   22            | ExtDir Width Width Width token
   23            | token
   24            | ExtDir token '=' Literal
   25            | ExtDir Width token '=' Literal

   26 Module_stuffs: Mstuff Module_stuffs
   27              | ε

   28 Mstuff: Definition
   29       | Assign
   30       | Instance
   31       | Always
   32       | Generate
   33       | Parameter
   34       | Localparam
   35       | Defparam
   36       | Initial
   37       | Function
   38       | Task
   39       | Define
   40       | Pragma
   41       | newver

   42 Define: define
   43       | define string
   44       | define token
   45       | define token Expr
   46       | define number token '/' number token

   47 Initial: initial Statement

   48 OneDef: token
   49       | token '=' Expr

   50 ManyDefs: ManyDefs ',' OneDef
   51         | OneDef

   52 Definition: ExtDir Tokens_list ';'
   53           | ExtDir Width Tokens_list ';'
   54           | ExtDir Width Tokens_list Width ';'
   55           | event Tokens_list ';'
   56           | IntDir ManyDefs ';'
   57           | IntDir Width ManyDefs ';'
   58           | IntDir Width Width ManyDefs ';'
   59           | IntDir Width Width Width OneDef ';'
   60           | IntDir Width token Width ';'
   61           | IntDir Width token Width Width ';'
   62           | IntDir Width Width token ';'
   63           | IntDir Width Width Width token ';'
   64           | IntDir token Width ';'
   65           | IntDir InstParams Tokens_list ';'
   66           | IntDir InstParams token '=' Expr ';'
   67           | typedef enum logic Width '{' Tokens_list '}' token ';'
   68           | typedef enum logic '{' Tokens_list '}' token ';'
   69           | typedef enum '{' Tokens_list '}' token ';'
   70           | typedef struct packed '{' RegDefines '}' token ';'
   71           | typedef struct '{' RegDefines '}' token ';'

   72 RegDefines: RegDefine RegDefines
   73           | RegDefine

   74 RegDefine: reg token ';'
   75          | logic token ';'
   76          | bit token ';'
   77          | reg Width token ';'
   78          | logic Width token ';'
   79          | bit Width token ';'

   80 Assign: assign Soft_assigns ';'
   81       | assign AssignParams LSH '=' Expr ';'
   82       | assign StrengthDef AssignParams LSH '=' Expr ';'
   83       | assign StrengthDef LSH '=' Expr ';'

   84 StrengthDef: '(' Strength ',' Strength ')'

   85 Strength: strong1
   86         | strong0
   87         | pull1
   88         | pull0
   89         | weak1
   90         | weak0
   91         | highz1
   92         | highz0

   93 WidthInt: Width
   94         | integer

   95 Function: function token ';' Mem_defs Statements endfunction
   96         | function token ';' Statements endfunction
   97         | function Width Width token ';' Mem_defs Statement endfunction
   98         | function WidthInt token ';' Mem_defs Statement endfunction
   99         | function WidthInt token ';' Statement endfunction
  100         | function token '(' Header_list ')' ';' Statement endfunction
  101         | function token '(' Header_list ')' ';' Mem_defs Statement endfunction
  102         | function automatic token '(' Header_list ')' ';' Statements endfunction
  103         | function automatic token '(' Header_list ')' ';' Mem_defs Statements endfunction
  104         | function automatic token token '(' Header_list ')' ';' Statements endfunction
  105         | function automatic token token '(' Header_list ')' ';' Mem_defs Statements endfunction
  106         | function automatic Width token '(' Header_list ')' ';' Statements endfunction
  107         | function automatic Width token '(' Header_list ')' ';' Mem_defs Statements endfunction
  108         | function WidthInt token '(' Header_list ')' ';' Statements endfunction
  109         | function WidthInt token '(' Header_list ')' ';' Mem_defs Statements endfunction

  110 Task: task token ';' Mem_defs Statement endtask
  111     | task token ';' Statement endtask
  112     | task token '(' Header_list ')' ';' Statement endtask
  113     | task token '(' Header_list ')' ';' Mem_defs Statement endtask

  114 Mem_defs: Mem_defs Mem_def
  115         | Mem_def

  116 Mem_def: reg Tokens_list ';'
  117        | real Tokens_list ';'
  118        | wreal Tokens_list ';'
  119        | reg Width Tokens_list ';'
  120        | logic Width Tokens_list ';'
  121        | bit Width Tokens_list ';'
  122        | logic Tokens_list ';'
  123        | bit Tokens_list ';'
  124        | reg Width token Width ';'
  125        | reg Width Width token ';'
  126        | output reg Width Width token ';'
  127        | input Tokens_list ';'
  128        | input Tokens_list Width ';'
  129        | input Width Width Tokens_list ';'
  130        | input Width Tokens_list ';'
  131        | input integer Tokens_list ';'
  132        | integer Tokens_list ';'
  133        | integer Tokens_list Width ';'
  134        | token token ';'

  135 Parameter: parameter Pairs ';'
  136          | parameter signed Pairs ';'
  137          | parameter Width Pairs ';'
  138          | parameter Width Width Pairs ';'
  139          | parameter signed Width Pairs ';'

  140 Localparam: localparam Pairs ';'
  141           | localparam Width Pairs ';'
  142           | localparam Width Width Pairs ';'

  143 Defparam: defparam Pairs ';'

  144 Pairs: Pairs ',' Pair
  145      | Pair

  146 Pair: token '=' Expr

  147 head_params: head_params ',' head_param
  148            | head_param

  149 head_param: localparam token '=' Expr
  150           | parameter token '=' Expr
  151           | parameter Width token '=' Expr
  152           | token '=' Expr

  153 Instance: token token '(' ')' ';'
  154         | token InstParams token '(' ')' ';'
  155         | token token ';'
  156         | or '(' Exprs ')' ';'
  157         | or token '(' Exprs ')' ';'
  158         | token token '(' Conns_list ')' ';'
  159         | or token '(' Conns_list ')' ';'
  160         | token token '(' Exprs ')' ';'
  161         | token '(' Exprs ')' ';'
  162         | token InstParams token '(' Conns_list ')' ';'
  163         | token InstParams token Width '(' Conns_list ')' ';'
  164         | token token Width '(' Conns_list ')' ';'
  165         | token token Width '(' Exprs ')' ';'

  166 Conns_list: Conns_list ',' Connection
  167           | Connection

  168 Connection: '.' '*'
  169           | '.' token '(' Expr ')'
  170           | '.' token '(' ')'
  171           | '.' token '[' number ']' '(' Expr ')'

  172 AssignParams: '#' '(' Exprs ')'
  173             | '#' number
  174             | '#' token
  175             | '#' floating

  176 Prms_list: Prms_list ',' PrmAssign
  177          | PrmAssign

  178 PrmAssign: '.' token '(' Expr ')'
  179          | '.' token

  180 InstParams: '#' '(' Exprs ')'
  181           | '#' number
  182           | '#' floating
  183           | '#' token
  184           | '#' '(' Prms_list ')'
  185           | '#' '(' ')'

  186 Always: always_ff When Statement
  187       | always_comb Statement
  188       | always Statement
  189       | always When Statement

  190 Generate: generate GenStatements endgenerate

  191 GenStatements: GenStatements GenStatement
  192              | GenStatement

  193 GenStatement: begin GenStatements end
  194             | begin ':' token GenStatements end
  195             | genvar Tokens_list ';'
  196             | Definition
  197             | Assign
  198             | Parameter
  199             | Localparam
  200             | Defparam
  201             | Instance
  202             | GenFor_statement
  203             | Always
  204             | Initial
  205             | Pragma
  206             | if '(' Expr ')' GenStatement
  207             | if '(' Expr ')' GenStatement else GenStatement
  208             | case '(' Expr ')' GenCases endcase
  209             | case '(' Expr ')' GenCases GenDefault endcase
  210             | case '(' Expr ')' GenDefault endcase

  211 GenFor_statement: for '(' Soft_assigns ';' Expr ';' Soft_assigns ')' GenStatement

  212 When: '@' '*'
  213     | '@' star
  214     | '@' token
  215     | '@' '(' When_items ')'

  216 Or_coma: or
  217        | ','

  218 When_items: When_items Or_coma When_item
  219           | When_item

  220 When_item: posedge Expr
  221          | negedge Expr
  222          | Expr

  223 Statement: begin Statements end
  224          | begin end
  225          | forever Statement
  226          | begin ':' token Statements end
  227          | fork Statements join
  228          | LSH '=' Expr ';'
  229          | LSH '=' AssignParams Expr ';'
  230          | LSH sm_eq Expr ';'
  231          | LSH sm_eq AssignParams Expr ';'
  232          | if '(' Expr ')' Statement
  233          | if '(' Expr ')' Statement else Statement
  234          | wait Expr ';'
  235          | integer Tokens_list ';'
  236          | int Tokens_list ';'
  237          | reg Tokens_list ';'
  238          | reg Width Tokens_list ';'
