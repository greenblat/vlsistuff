Grammar

    0 $accept: Main $end

    1 Main: Mains

    2 Mains: Mains MainItem
    3      | MainItem

    4 MainItem: Module
    5         | Define

    6 Module: module token Hparams Header Module_stuffs endmodule
    7       | module token Hparams Header endmodule
    8       | module token Header Module_stuffs endmodule
    9       | module token Header endmodule

   10 Hparams: '#' '(' head_params ')'
   11        | '#' '(' ')'

   12 Header: ';'
   13       | '(' Header_list ')' ';'
   14       | '(' ')' ';'

   15 Header_list: Header_list ',' Header_item
   16            | Header_item

   17 Header_item: ExtDir token
   18            | ExtDir Width token
   19            | ExtDir integer token
   20            | ExtDir Width token Width
   21            | ExtDir Width Width token
   22            | ExtDir Width Width Width token
   23            | ExtDir Width token Width Width
   24            | ExtDir Width token Width Width Width
   25            | ExtDir Width Width Width Width token
   26            | token
   27            | ExtDir token '=' Literal
   28            | ExtDir Width token '=' Literal

   29 Module_stuffs: Mstuff Module_stuffs
   30              | ε

   31 Mstuff: Definition
   32       | Assign
   33       | Instance
   34       | Always
   35       | Generate
   36       | Parameter
   37       | Localparam
   38       | Defparam
   39       | Initial
   40       | Function
   41       | Task
   42       | Define
   43       | Pragma
   44       | newver

   45 Define: define
   46       | define string
   47       | define token
   48       | define token Expr
   49       | define number token '/' number token

   50 Initial: initial Statement

   51 OneDef: token
   52       | token '=' Expr

   53 ManyDefs: ManyDefs ',' OneDef
   54         | OneDef

   55 Definition: ExtDir Tokens_list ';'
   56           | ExtDir Width Tokens_list ';'
   57           | ExtDir Width Tokens_list Width ';'
   58           | event Tokens_list ';'
   59           | IntDir ManyDefs ';'
   60           | IntDir Width ManyDefs ';'
   61           | IntDir Width Width ManyDefs ';'
   62           | IntDir Width Width Width OneDef ';'
   63           | IntDir Width token Width ';'
   64           | IntDir Width token Width Width ';'
   65           | IntDir Width Width token ';'
   66           | IntDir Width Width Width token ';'
   67           | IntDir token Width ';'
   68           | IntDir InstParams Tokens_list ';'
   69           | IntDir InstParams token '=' Expr ';'
   70           | typedef enum logic Width '{' Tokens_list '}' token ';'
   71           | typedef enum logic '{' Tokens_list '}' token ';'
   72           | typedef enum '{' Tokens_list '}' token ';'
   73           | typedef struct packed '{' RegDefines '}' token ';'
   74           | typedef struct '{' RegDefines '}' token ';'

   75 RegDefines: RegDefine RegDefines
   76           | RegDefine

   77 RegDefine: reg token ';'
   78          | logic token ';'
   79          | bit token ';'
   80          | reg Width token ';'
   81          | logic Width token ';'
   82          | bit Width token ';'

   83 Assign: assign Soft_assigns ';'
   84       | assign AssignParams LSH '=' Expr ';'
   85       | assign StrengthDef AssignParams LSH '=' Expr ';'
   86       | assign StrengthDef LSH '=' Expr ';'

   87 StrengthDef: '(' Strength ',' Strength ')'

   88 Strength: strong1
   89         | strong0
   90         | pull1
   91         | pull0
   92         | weak1
   93         | weak0
   94         | highz1
   95         | highz0

   96 WidthInt: Width
   97         | integer

   98 Function: function token ';' Mem_defs Statements endfunction
   99         | function token ';' Statements endfunction
  100         | function Width Width token ';' Mem_defs Statement endfunction
  101         | function WidthInt token ';' Mem_defs Statement endfunction
  102         | function automatic Width token ';' Mem_defs Statement endfunction
  103         | function automatic token ';' Mem_defs Statement endfunction
  104         | function WidthInt token ';' Statement endfunction
  105         | function token '(' Header_list ')' ';' Statement endfunction
  106         | function token '(' Header_list ')' ';' Mem_defs Statement endfunction
  107         | function automatic token '(' Header_list ')' ';' Statements endfunction
  108         | function automatic token '(' Header_list ')' ';' Mem_defs Statements endfunction
  109         | function automatic token token '(' Header_list ')' ';' Statements endfunction
  110         | function automatic token token '(' Header_list ')' ';' Mem_defs Statements endfunction
  111         | function automatic Width token '(' Header_list ')' ';' Statements endfunction
  112         | function automatic Width token '(' Header_list ')' ';' Mem_defs Statements endfunction
  113         | function WidthInt token '(' Header_list ')' ';' Statements endfunction
  114         | function WidthInt token '(' Header_list ')' ';' Mem_defs Statements endfunction

  115 Task: task token ';' Mem_defs Statement endtask
  116     | task token ';' Statement endtask
  117     | task token '(' Header_list ')' ';' Statement endtask
  118     | task token '(' Header_list ')' ';' Mem_defs Statement endtask

  119 Mem_defs: Mem_defs Mem_def
  120         | Mem_def

  121 Mem_def: reg Tokens_list ';'
  122        | real Tokens_list ';'
  123        | wreal Tokens_list ';'
  124        | reg Width Tokens_list ';'
  125        | reg signed Width Tokens_list ';'
  126        | logic Width Tokens_list ';'
  127        | bit Width Tokens_list ';'
  128        | logic Tokens_list ';'
  129        | bit Tokens_list ';'
  130        | reg Width token Width ';'
  131        | reg Width Width token ';'
  132        | output reg Width Width token ';'
  133        | input Tokens_list ';'
  134        | input Tokens_list Width ';'
  135        | input Width Width Tokens_list ';'
  136        | input Width Tokens_list ';'
  137        | input signed Width Tokens_list ';'
  138        | input integer Tokens_list ';'
  139        | integer Tokens_list ';'
  140        | integer Tokens_list Width ';'
  141        | token token ';'

  142 Parameter: parameter Pairs ';'
  143          | parameter signed Pairs ';'
  144          | parameter Width Pairs ';'
  145          | parameter Width Width Pairs ';'
  146          | parameter signed Width Pairs ';'

  147 Localparam: localparam Pairs ';'
  148           | localparam Width Pairs ';'
  149           | localparam Width Width Pairs ';'

  150 Defparam: defparam Pairs ';'

  151 Pairs: Pairs ',' Pair
  152      | Pair

  153 Pair: token '=' Expr

  154 head_params: head_params ',' head_param
  155            | head_param

  156 head_param: localparam token '=' Expr
  157           | parameter token '=' Expr
  158           | parameter Width token '=' Expr
  159           | token '=' Expr

  160 Instance: token token '(' ')' ';'
  161         | token InstParams token '(' ')' ';'
  162         | token token ';'
  163         | or '(' Exprs ')' ';'
  164         | or token '(' Exprs ')' ';'
  165         | token token '(' Conns_list ')' ';'
  166         | or token '(' Conns_list ')' ';'
  167         | token token '(' Exprs ')' ';'
  168         | token '(' Exprs ')' ';'
  169         | token InstParams token '(' Conns_list ')' ';'
  170         | token InstParams token Width '(' Conns_list ')' ';'
  171         | token token Width '(' Conns_list ')' ';'
  172         | token token Width '(' Exprs ')' ';'

  173 Conns_list: Conns_list ',' Connection
  174           | Connection

  175 Connection: '.' '*'
  176           | '.' token '(' Expr ')'
  177           | '.' token '(' ')'
  178           | '.' token '[' number ']' '(' Expr ')'

  179 AssignParams: '#' '(' Exprs ')'
  180             | '#' number
  181             | '#' token
  182             | '#' floating

  183 Prms_list: Prms_list ',' PrmAssign
  184          | PrmAssign

  185 PrmAssign: '.' token '(' Expr ')'
  186          | '.' token

  187 InstParams: '#' '(' Exprs ')'
  188           | '#' number
  189           | '#' floating
  190           | '#' token
  191           | '#' '(' Prms_list ')'
  192           | '#' '(' ')'

  193 Always: always_ff When Statement
  194       | always_comb Statement
  195       | always Statement
  196       | always When Statement

  197 Generate: generate GenStatements endgenerate

  198 GenStatements: GenStatements GenStatement
  199              | GenStatement

  200 GenStatement: begin GenStatements end
  201             | begin ':' token GenStatements end
  202             | genvar Tokens_list ';'
  203             | Definition
  204             | Assign
  205             | Parameter
  206             | Localparam
  207             | Defparam
  208             | Instance
  209             | GenFor_statement
  210             | Always
  211             | Initial
  212             | Pragma
  213             | if '(' Expr ')' GenStatement
  214             | if '(' Expr ')' GenStatement else GenStatement
  215             | case '(' Expr ')' GenCases endcase
  216             | case '(' Expr ')' GenCases GenDefault endcase
  217             | case '(' Expr ')' GenDefault endcase

  218 GenFor_statement: for '(' Soft_assigns ';' Expr ';' Soft_assigns ')' GenStatement

  219 When: '@' '*'
  220     | '@' star
  221     | '@' token
  222     | '@' '(' When_items ')'

  223 Or_coma: or
  224        | ','

  225 When_items: When_items Or_coma When_item
  226           | When_item

  227 When_item: posedge Expr
  228          | negedge Expr
  229          | Expr

  230 Statement: begin Statements end
  231          | begin end
  232          | forever Statement
  233          | begin ':' token Statements end
  234          | fork Statements join
  235          | LSH '=' Expr ';'
  236          | LSH '=' AssignParams Expr ';'
  237          | LSH sm_eq Expr ';'
  238          | LSH sm_eq AssignParams Expr ';'
  239          | if '(' Expr ')' Statement
  240          | if '(' Expr ')' Statement else Statement
  241          | wait Expr ';'
  242          | integer Tokens_list ';'
  243          | int Tokens_list ';'
  244          | reg Tokens_list ';'
  245          | reg Width Tokens_list ';'
  246          | reg signed Width Tokens_list ';'
  247          | release Expr ';'
  248          | force Expr '=' Expr ';'
  249          | When ';'
  250          | emit token ';'
  251          | disable token ';'
  252          | token '(' ')' ';'
  253          | token '(' Exprs ')' ';'
  254          | case '(' Expr ')' Cases endcase
  255          | case '(' Expr ')' Cases Default endcase
  256          | case '(' Expr ')' Default endcase
  257          | casez '(' Expr ')' Cases endcase
  258          | casez '(' Expr ')' Cases Default endcase
  259          | casex '(' Expr ')' Cases endcase
  260          | casex '(' Expr ')' Cases Default endcase
  261          | '#' Expr ';'
  262          | '#' Expr Statement
  263          | token ';'
  264          | For_statement
  265          | Repeat_statement
  266          | While_statement
  267          | Pragma
  268          | assign LSH '=' Expr ';'
  269          | return token ';'
  270          | assert '(' Expr ')' ';'
  271          | assert '(' Expr ')' else Statement

  272 pragma_stuffs: pragma_stuffs ',' pragma_item
  273              | pragma_item

  274 pragma_item: token '=' Expr
  275            | string

  276 Pragma: pragma1 pragma_stuffs pragma2

  277 For_statement: for '(' Soft_assigns ';' Expr ';' Soft_assigns ')' Statement
  278              | for '(' int Soft_assign ';' Expr ';' Soft_assigns ')' Statement

  279 Repeat_statement: repeat '(' Expr ')' Statement

  280 While_statement: while '(' Expr ')' Statement

  281 Soft_assigns: Soft_assigns ',' Soft_assign
  282             | Soft_assign

  283 Soft_assign: LSH '=' Expr
  284            | LSH plus_plus

  285 Cases: Cases Case
  286      | Case

  287 GenCases: GenCases GenCase
  288         | GenCase

  289 Case: Exprs ':' Statement
  290     | Exprs ':' ';'

  291 GenCase: Exprs ':' GenStatement
  292        | Exprs ':' ';'

  293 Default: default ':' Statement
  294        | default ':' ';'

  295 GenDefault: default ':' GenStatement
  296           | default ':' ';'

  297 Exprs: Exprs ',' Expr
  298      | Expr

  299 Statements: Statements Statement
  300           | Statement

  301 LSH: token
  302    | token Width
  303    | token BusBit Width
  304    | token BusBit BusBit
  305    | token BusBit
  306    | CurlyList

  307 Tokens_list: token ',' Tokens_list
  308            | token

  309 Width: '[' Expr ':' Expr ']'
  310      | '[' Expr plus_range Expr ']'
  311      | '[' Expr minus_range Expr ']'

  312 BusBit: '[' Expr ']'

  313 ExtDir: input
  314       | output
  315       | inout
  316       | output reg
  317       | input wire
  318       | output wire
  319       | inout wire
  320       | input signed
